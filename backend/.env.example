# ── Backend .env.example ─────────────────────────────────────────────────────
# Copy to .env and fill in your real values.
# The root .env.example is the canonical source; this mirrors backend-only vars.

NODE_ENV=development
PORT=5000

# MongoDB Atlas URI — see handouts/12-mongodb-atlas-setup.md
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/devlog?retryWrites=true&w=majority

# JWT settings
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS allowed origins (comma separated)
CORS_ORIGINS=http://localhost:5173
