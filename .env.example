# ============================================================================
# The Dev Guy — Root Environment Variables
# Copy this file to .env and fill in your values.
#
# These variables are shared by start-backend.sh and start-frontend.sh.
# For Docker / K3s deployments see:
#   deployment/environments/dev/  (dev values)
#   deployment/environments/prod/ (prod values)
# ============================================================================

# ── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Setup guide: see handouts/12-mongodb-atlas-setup.md
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/devlog?retryWrites=true&w=majority

# JWT secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
# Vite exposes env vars prefixed with VITE_ to the browser bundle
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=DevLog
